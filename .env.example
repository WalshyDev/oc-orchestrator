# Path to the opencode binary (optional, defaults to system PATH lookup)
# OPENCODE_PATH=/usr/local/bin/opencode

# Custom path for the SQLite database file (optional)
# OC_ORCHESTRATOR_DB_PATH=~/.oc-orchestrator/data.db

# Custom root directory for git worktrees (optional)
# OC_ORCHESTRATOR_WORKTREE_ROOT=~/.oc-orchestrator/worktrees

# Logging level: debug | info | warn | error (default: info)
# OC_ORCHESTRATOR_LOG_LEVEL=info
