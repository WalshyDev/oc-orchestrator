{
  "name": "oc-orchestrator",
  "version": "0.1.1",
  "description": "OpenCode Orchestrator — supervise concurrent coding agents",
  "main": "./out/main/index.js",
  "bin": {
    "oc-orchestrator": "./bin/oc-orchestrator.js"
  },
  "files": [
    "bin/",
    "out/",
    "scripts/",
    "resources/icon.png",
    "resources/icon.icns",
    "resources/icon.svg"
  ],
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "node scripts/postinstall.js",
    "lint": "eslint .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:integration": "OPENCODE_INTEGRATION=1 vitest run integration",
    "prepublishOnly": "npm run build",
    "release": "npm run typecheck && npm run test && npm version patch && npm publish",
    "release:minor": "npm run typecheck && npm run test && npm version minor && npm publish",
    "release:major": "npm run typecheck && npm run test && npm version major && npm publish"
  },
  "engines": {
    "node": "24.14.0"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.3.3",
    "@phosphor-icons/react": "^2.1.7",
    "@rollup/rollup-darwin-arm64": "4.60.0",
    "electron": "41.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/parser": "8.57.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.1.0",
    "globals": "17.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^6.0.2",
    "vitest": "4.1.2"
  }
}
